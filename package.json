{
  "name": "cosmonauts",
  "private": true,
  "version": "0.3.1",
  "description": "Open-source, browser-based 2D action-platformer MOBA",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @cosmonauts/client dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "sim:bench": "pnpm --filter @cosmonauts/server bench"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
